homeassistant:
  url: http://homeassistant.local:8123
  token: !secret ha_token   # or paste token directly as a string

mqtt:
  url: mqtt://localhost:1883

automations:
  dir: ./automations

# Optional — defaults shown
server:
  port: 7070
  shutdown_timeout_ms: 10000

options:
  dry_run: false

metrics:
  enabled: false   # set to true to expose Prometheus metrics at GET /metrics
